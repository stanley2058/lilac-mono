{
  "name": "@stanley2058/mini-lilac",
  "version": "0.0.1",
  "description": "Local Mini Lilac coding-agent terminal client and server.",
  "keywords": [
    "ai",
    "coding-agent",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stanley2058/lilac-mono.git",
    "directory": "apps/mini-lilac"
  },
  "homepage": "https://github.com/stanley2058/lilac-mono/tree/main/apps/mini-lilac#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "mini-lilac": "dist/main.js"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build.ts && chmod +x dist/main.js",
    "install:local": "bun install-local.ts",
    "pack:npm": "bun run build && npm pack --workspaces=false ./dist",
    "publish:npm": "bun run build && npm publish --workspaces=false ./dist",
    "test": "bun test",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.4.3"
  },
  "devDependencies": {
    "@opentui/solid": "0.4.3",
    "@types/bun": "^1.3.14",
    "zod": "^4.3.6"
  }
}
